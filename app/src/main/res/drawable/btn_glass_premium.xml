<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <layer-list>
            <!-- 1. External Shadow -->
            <item>
                <shape android:shape="rectangle">
                    <padding android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp"/>
                    <solid android:color="#4D000000"/>
                    <corners android:radius="26dp"/>
                </shape>
            </item>

            <!-- 2. Refractive Glass Rim -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="225"
                        android:startColor="#66FFFFFF"
                        android:centerColor="#1AFFFFFF"
                        android:endColor="#40FFFFFF" />
                    <corners android:radius="24dp"/>
                </shape>
            </item>

            <!-- 3. Main Dark Liquid Body (Matched to Bottom Sheet) -->
            <item android:top="1.5dp" android:left="1.5dp" android:right="1.5dp" android:bottom="1.5dp">
                <shape android:shape="rectangle">
                    <solid android:color="#F208081A"/>
                    <corners android:radius="23dp"/>
                    <gradient
                        android:angle="135"
                        android:startColor="#261A1040"
                        android:centerColor="#050510"
                        android:endColor="#0DFFFFFF" />
                </shape>
            </item>

            <!-- 4. Surface Specular Shine -->
            <item android:top="1.5dp" android:left="15dp" android:right="15dp" android:bottom="36dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="#33FFFFFF"
                        android:endColor="#00FFFFFF" />
                    <corners android:radius="10dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>