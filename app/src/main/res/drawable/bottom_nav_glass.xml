<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Ambient Shadow -->
    <item>
        <shape android:shape="rectangle">
            <padding android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp"/>
            <solid android:color="#1A000000"/>
            <corners android:radius="32dp"/>
        </shape>
    </item>

    <!-- Glass High-Definition Border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40FFFFFF"/>
            <corners android:radius="32dp"/>
        </shape>
    </item>

    <!-- Main Frosted Body -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <!-- Semi-transparent nocturnal base for legibility, with glass frost -->
            <solid android:color="#CC08081A"/>
            <corners android:radius="31dp"/>
            <gradient
                android:angle="135"
                android:startColor="#1AFFFFFF"
                android:endColor="#0DFFFFFF" />
        </shape>
    </item>

    <!-- Specular Highlight (Top Rim Reflection) -->
    <item android:top="1dp" android:left="32dp" android:right="32dp" android:bottom="68dp">
        <shape android:shape="rectangle">
            <solid android:color="#20FFFFFF"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>