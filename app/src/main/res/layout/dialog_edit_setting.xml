<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/glass_bottom_sheet"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/drag_handle_bg" />

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:fontFamily="sans-serif-medium"
        android:text="Edit Setting"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/etDialogInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_button"
            android:fontFamily="sans-serif"
            android:hint="Enter value"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:textColor="@color/white"
            android:textColorHint="#55556A"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivDialogToggle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:alpha="0.6"
            android:src="@drawable/ic_help"
            android:visibility="gone"
            app:tint="@color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FF4757"
        android:textSize="12sp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/btn_glass_premium"
        app:backgroundTint="@null"
        android:fontFamily="sans-serif-medium"
        android:text="Save"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:cornerRadius="26dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogCancel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_glass_premium"
        app:backgroundTint="@null"
        android:fontFamily="sans-serif-medium"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="#9999BB"
        android:textStyle="normal"
        app:cornerRadius="26dp" />

</LinearLayout>
