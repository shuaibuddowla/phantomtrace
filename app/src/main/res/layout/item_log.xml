<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_card_dark"
        android:orientation="horizontal">

        <View
            android:id="@+id/leftAccent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="12dp"
            android:background="#00E5A0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <FrameLayout
                android:id="@+id/statusIconContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/status_circle_glass">

                <ImageView
                    android:id="@+id/ivLogStatusIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check"
                    app:tint="#00E5A0" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLogNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="+1 234 567 890"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLogTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="2:45 PM"
                    android:textColor="#9999BB"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLogAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Location captured"
                    android:textColor="#55556A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLogStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_success"
                android:fontFamily="sans-serif"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="SUCCESS"
                android:textColor="#00E5A0"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
