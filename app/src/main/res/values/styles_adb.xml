<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AdbStepCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:background">@drawable/glass_card_dark</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="AdbStepTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AdbStepSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="AdbStepDesc">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:lineSpacingExtra">3dp</item>
        <item name="android:textColor">#9999BB</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="AdbCopyButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:background">@drawable/glass_pill</item>
        <item name="android:text">Copy</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#8B7FF5</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="RequirementsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:background">@drawable/bg_requirements_card</item>
        <item name="android:padding">14dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="TransparentBottomSheetDialog" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>